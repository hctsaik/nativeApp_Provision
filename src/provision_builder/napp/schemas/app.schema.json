{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CV Reviewer application declaration (app.yaml / app.json)",
  "type": "object",
  "required": ["id", "version"],
  "properties": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "version": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "entrypoint": {"type": "string", "description": "Optional launch hint; the nativeApp engine runner owns process startup."},
    "category": {"type": "string"},
    "source_root": {"type": "string"},
    "requires": {"type": "array", "items": {"type": "string"}},
    "big_deps": {"type": "array", "items": {"type": "string"}},
    "healthcheck": {"type": "object"},
    "data_dirs": {"type": "array", "items": {"type": "string"}},
    "migrations": {"type": "string"}
  }
}
